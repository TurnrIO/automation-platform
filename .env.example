# ── Core ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://automations:automations@db:5432/automations
REDIS_URL=redis://redis:6379/0

# Change these before any public deployment
API_KEY=dev_api_key
ADMIN_TOKEN=dev_admin_token

# ── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Integrations ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI — required for action.llm_call
OPENAI_API_KEY=

# Slack incoming webhook — used by action.slack and failure notifications
SLACK_WEBHOOK_URL=

# ── Failure notifications ─────────────────────────────────────────────────
# Set either or both to receive alerts when any run fails.
NOTIFY_SLACK_WEBHOOK=
NOTIFY_EMAIL=

# ── Webhook rate limiting ─────────────────────────────────────────────────
# Max webhook calls per token per window. Set WEBHOOK_RATE_LIMIT=0 to disable.
WEBHOOK_RATE_LIMIT=60
WEBHOOK_RATE_WINDOW=60
